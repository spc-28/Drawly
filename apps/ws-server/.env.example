# JWT_SECRET is shared — set it in packages/backend-common/.env

# Upstash uses rediss:// (TLS); the URL already contains the password
REDIS_URL=redis://localhost:6379

# Worker (Cloud Run Job) only: idle ms with an empty queue before it exits
WORKER_IDLE_MS=15000

# Local port only; Cloud Run injects PORT and overrides this
WS_PORT=8080
